// ═══════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════

// Normalize an author surname to a plain lowercase string.
// García-López / García–López / García—López → garcia
function normAuthor(n) {
  const base = n.trim().split(/[-–—]/)[0].trim();
  return base.toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z]/g, '');
}
function makeKey(name, year) { return normAuthor(name) + '_' + year; }

// Surname particles to skip when scanning for first author word.
// "De la Torre" → skip "De" → return "Torre"; consistent with refs starting "de la Torre"
const PARTICLES = new Set([
  'de','del','da','di','du','van','von','le','les','des','dos','af','av','ap','al'
]);

// Connectors/prepositions that can precede an author name but are NOT surnames.
// Needed because the two-word narrative regex can capture "Según Shi" as an author pair.
const CONNECTORS = new Set([
  'según','segun','para','como','así','asi','también','tambien','además','ademas',
  'donde','cuando','mientras','durante','conforme','mediante','ante','tras','desde',
  'entre','sin','bajo','sobre','no','ni','pero','sino','aunque','incluso','incluyendo',
  'after','before','although','however','therefore','thus','hence','whereas','per','via'
]);

// Words that are NOT author surnames (appear before years but don't belong to a person)
const NON_AUTHORS = new Set([
  'figura','figure','tabla','table','cuadro','grafico','grafica','chart','graph',
  'mapa','map','diagrama','diagram','esquema','panel','anexo','appendix',
  'capitulo','chapter','seccion','section','parte','part','pagina','page',
  'ley','decreto','codigo','norma','resolucion','reglamento','articulo',
  'publica','publico','nacional','general','federal','central','regional',
  'mundial','internacional','especial','principal','local',
  'version','edicion','edition','volumen','volume','numero','number','tomo'
]);

// Scan a text fragment word by word and return the first word that looks like
// an author surname: starts with uppercase, length ≥ 2, not in NON_AUTHORS.
// This naturally handles "véase García, 2020", "García y López, 2020", "et al." etc.
function findFirstAuthor(text) {
  if (!text) return null;
  for (const w of text.trim().normalize('NFC').split(/\s+/)) {
    const c = w.replace(/^\P{L}+/u, '').replace(/[^\p{L}\-]+$/gu, '');
    if (c.length < 2 || !/^\p{Lu}/u.test(c)) continue;
    const norm = normAuthor(c);
    if (norm.length < 2 || NON_AUTHORS.has(norm) || PARTICLES.has(norm) || CONNECTORS.has(norm)) continue;
    return c;
  }
  return null;
}

// Extract {name, year} from a citation fragment like:
//  "García y López, 2020"   "véase García, 2020"   "García, 2020, p. 45"
//  Also handles semicolon before year: "Di Rienzo et al; 2008"
function parseCitFragment(frag) {
  frag = frag.trim();
  const ym = frag.match(/[,;]\s*(\d{4}[a-z]?)\b/);
  if (!ym) return null;
  const year = ym[1];
  const beforeYear = frag.slice(0, frag.indexOf(ym[0]));
  const name = findFirstAuthor(beforeYear);
  return name ? { name, year } : null;
}

function escHtml(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function fmtSize(b) {
  if (b < 1024) return b + ' B';
  if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
  return (b/1048576).toFixed(1) + ' MB';
}

function debounce(fn, ms) {
  let t; return function(...a){ clearTimeout(t); t=setTimeout(()=>fn(...a),ms); };
}

// ═══════════════════════════════════════
// PARSING
// ═══════════════════════════════════════
function splitDoc(text) {
  // Normalize: lowercase, strip accents, keep only letters and spaces
  function normLine(s) {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').replace(/[^a-z\s]/g,'').trim();
  }
  // Levenshtein distance for typo detection
  function lev(a, b) {
    const dp = Array.from({length:a.length+1},(_,i)=>Array.from({length:b.length+1},(_,j)=>i||j));
    for (let i=1;i<=a.length;i++)
      for (let j=1;j<=b.length;j++)
        dp[i][j]=a[i-1]===b[j-1]?dp[i-1][j-1]:1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);
    return dp[a.length][b.length];
  }
  // Anchor keywords (normalized, no accents): any heading line containing one of these is the ref section
  // Covers: Referencias / Referencia / References / Reference / Bibliografía / Bibliografias /
  //         Bibliography / Bibliographies / Fuentes bibliográficas / Lista de referencias /
  //         Referencias citadas / Works Cited / Literature Cited / Sources
  const ANCHORS = [
    // Español
    'referencias','referencia',
    'bibliografia','bibliografias','bibliograficas','bibliografica',
    'fuentesbibliograficas','fuentesdeinformacion','fuentesconsultadas','fuentesdereferencia',
    'listadereferencias','listadodereferencias','referenciascitadas','referenciasconsultadas',
    'literaturacitada','obrascitadas','obrasconsultadas',
    // English
    'references','reference',
    'bibliography','bibliographies',
    'workscited','citedworks','worksreferenced',
    'literaturecited','citedreferences','referencelist','referenceslist',
    'worksconsulted','sourcesconsulted','sources','sourcelist'
  ];

  const lines = text.split('\n');
  for (let i = 0; i < lines.length; i++) {
    const tr = lines[i].trim();
    if (!tr || tr.length > 80) continue;

    // Strip leading numbering / bullets (e.g. "5.", "IV.", "5)", "•")
    const stripped = tr.replace(/^[\d]+[.):\-]\s*/,'').replace(/^[IVXivx]+[.):\-]\s*/,'').replace(/^[•\-–—*]\s*/,'').trim();
    const norm = normLine(stripped);
    if (!norm) continue;

    const words = norm.split(/\s+/);

    // 1. Exact anchor match: any word in the line matches an anchor exactly
    for (const w of words) {
      if (w.length < 6) continue;
      if (ANCHORS.includes(w)) return { body: lines.slice(0,i).join('\n'), refs: lines.slice(i+1).join('\n'), found: true };
    }

    // 2. Compact match: entire line (no spaces) matches an anchor
    //    e.g. "Lista de referencias" → "listadereferencias"
    const compact = norm.replace(/\s+/g,'');
    if (ANCHORS.includes(compact)) return { body: lines.slice(0,i).join('\n'), refs: lines.slice(i+1).join('\n'), found: true };

    // 3. Typo tolerance: first word ≤ 2 edits from an anchor (only on short heading lines ≤ 3 words)
    if (words.length <= 3) {
      const fw = words[0];
      if (fw.length >= 6) {
        for (const anchor of ANCHORS) {
          if (Math.abs(fw.length - anchor.length) <= 2 && lev(fw, anchor) <= 2) {
            return { body: lines.slice(0,i).join('\n'), refs: lines.slice(i+1).join('\n'), found: true };
          }
        }
      }
    }
  }
  return { body: text, refs: '', found: false };
}

function extractCitations(bodyText) {
  const map = new Map();
  let m;

  const reParen = /\(([^()]{2,200})\)/g;
  while ((m = reParen.exec(bodyText)) !== null) {
    const inner = m[1];
    if (!/[,;] ?\d{4}/.test(inner)) continue;

    // Split only on ";" followed by a letter — avoids breaking "et al; 2008" patterns
    const segs = inner.split(/;\s*(?=\p{L})/u);
    const isMulti = segs.length > 1;

    segs.forEach(seg => {
      const pair = parseCitFragment(seg);
      if (!pair) return;
      const key = makeKey(pair.name, pair.year);
      if (!map.has(key)) {
        map.set(key, { key, fa: pair.name, year: pair.year,
          type: isMulti ? 'mul' : 'par', isMulti, raw: m[0] });
      } else {
        if (isMulti) map.get(key).isMulti = true;
      }
    });
  }

  // Narrative: Author (Year) — handles single word, two-word surnames, initials,
  // two-author (Osorio & Habte), et al., and comma before year: "et al., (2010)"
  const ARTICLES = /^(el|la|los|las|un|una|the|a|an|de|del|en|al|lo|le|su|por|con|si|que|y|o|e|i|según|segun|para|como|así|asi|también|tambien|además|ademas|donde|cuando|mientras|durante|conforme|mediante|ante|tras|desde|entre|sin|bajo|sobre|after|before|per|via|no|ni|pero|sino|aunque|however|although|therefore|thus|hence|as|by|from|with|without|into|onto|upon|within)$/i;
  const reNarr = /(\p{Lu}[\p{L}\-']{1,35}(?:\s+(?:\p{Lu}[\p{L}\-']{1,35}|\p{Lu}\.?))?(?:\s*(?:&|y)\s*\p{Lu}[\p{L}\-']{1,35})?(?:\s+et\s+al\.)?),?\s+\((\d{4}[a-z]?)\)/gu;
  while ((m = reNarr.exec(bodyText)) !== null) {
    const before = bodyText.slice(Math.max(0, m.index - 80), m.index).trimEnd();
    const prev = before.match(/(\S+)\s+(\S+)?\s*$/) || [];
    const w1 = (prev[1] || '').replace(/[,;:.()[\]]/g, '');
    const w2 = (prev[2] || '').replace(/[,;:.()[\]]/g, '');
    // Preceding capitalized non-article word → likely last word of org/title name → skip
    if ([w1, w2].some(w => w.length > 1 && /^\p{Lu}/u.test(w) && !ARTICLES.test(w))) continue;

    const authorStr = m[1].replace(/\s+et\s+al\.?/gi, '').trim();
    const fa = findFirstAuthor(authorStr);
    if (!fa) continue;
    const year = m[2];
    const key = makeKey(fa, year);
    if (!map.has(key)) {
      map.set(key, { key, fa, year, type: 'nar', isMulti: false, raw: m[0] });
    }
  }

  return Array.from(map.values());
}

function parseRefList(refText) {
  const map = new Map();
  let entries = [];

  // Prefer blank-line separation (preserved when pasting from Word/PDF)
  if (/\n\s*\n/.test(refText)) {
    entries = refText.split(/\n\s*\n/)
      .map(b => b.replace(/\n/g, ' ').replace(/\s{2,}/g, ' ').trim())
      .filter(b => b.length > 5);
  } else {
    // Fallback: new entry when a line starts with a capital letter
    const lines = refText.split('\n').map(l => l.trim()).filter(l => l.length > 2);
    let cur = '';
    for (const line of lines) {
      if (/^\p{Lu}/u.test(line) && cur) { entries.push(cur.trim()); cur = line; }
      else cur = cur ? cur + ' ' + line : line;
    }
    if (cur.trim().length > 5) entries.push(cur.trim());
  }

  const dups = [];
  entries.forEach(entry => {
    if (entry.length < 10) return;
    const ym = entry.match(/\((\d{4}[a-z]?)\)/);
    if (!ym) return;
    const year = ym[1];
    const fa = findFirstAuthor(entry.slice(0, entry.indexOf('(' + ym[1] + ')')));
    if (!fa) return;
    const key = makeKey(fa, year);
    if (!map.has(key)) {
      map.set(key, { key, fa, year, raw: entry, type: 'ref' });
    } else {
      dups.push({ key, fa, year, raw: entry, type: 'ref', iss: 'dup' });
    }
  });

  return { refs: Array.from(map.values()), dups };
}

// ═══════════════════════════════════════
// ANALYSIS
// ═══════════════════════════════════════
function runAnalysis() {
  const tab = document.querySelector('.tab-btn.active').dataset.tab;
  const raw = tab === 'paste' ? document.getElementById('text-body').value : S.rawText;
  if (!raw.trim()) return;

  const { body, refs, found } = splitDoc(raw);
  if (!found) { alert(stripHtml(t('notice.warn'))); return; }

  const cits = extractCitations(body);
  const { refs: rrefs, dups: dupRefs } = parseRefList(refs);
  S.citations = cits; S.references = rrefs;
  S.date = new Date().toLocaleDateString(S.lang==='es'?'es-CR':'en-US',{year:'numeric',month:'long',day:'numeric'});

  const citKeys = new Set(cits.map(c=>c.key));
  const refKeys = new Set(rrefs.map(r=>r.key));
  const issues = [];

  // Strips letter suffix for soft-match: garcia_2020a → garcia_2020
  const baseKey = k => k.replace(/_(\d{4})[a-z]$/, '_$1');

  cits.forEach(c => {
    if (refKeys.has(c.key)) return;
    const nearRef = rrefs.some(r => baseKey(r.key) === baseKey(c.key) && r.key !== c.key);
    issues.push({...c, iss: nearRef ? 'soft' : 'huer'});
  });
  rrefs.forEach(r => {
    if (citKeys.has(r.key)) return;
    const nearCit = cits.some(c => baseKey(c.key) === baseKey(r.key) && c.key !== r.key);
    issues.push({...r, iss: nearCit ? 'soft' : 'fant'});
  });
  dupRefs.forEach(d => issues.push(d));

  S.issues = issues;
  renderResults();
}

// ═══════════════════════════════════════
// RENDER
// ═══════════════════════════════════════
function renderResults() {
  const { citations: C, references: R, issues: I } = S;
  const huer = I.filter(x=>x.iss==='huer').length;
  const fant = I.filter(x=>x.iss==='fant').length;
  const mult = C.filter(c=>c.isMulti).length;
  const soft = I.filter(x=>x.iss==='soft').length;
  const dup  = I.filter(x=>x.iss==='dup').length;
  const ok   = C.filter(c=>R.some(r=>r.key===c.key)).length;

  document.getElementById('stats-row').innerHTML = `
    <div class="stat-card s-citas"><div class="stat-num">${C.length}</div><div class="stat-label">${t('stat.citas')}</div></div>
    <div class="stat-card s-refs"><div class="stat-num">${R.length}</div><div class="stat-label">${t('stat.refs')}</div></div>
    <div class="stat-card s-huer"><div class="stat-num">${huer}</div><div class="stat-label">${t('stat.huer')}</div></div>
    <div class="stat-card s-fant"><div class="stat-num">${fant}</div><div class="stat-label">${t('stat.fant')}</div></div>
    <div class="stat-card s-mult"><div class="stat-num">${mult}</div><div class="stat-label">${t('stat.mult')}</div></div>
    <div class="stat-card s-ok"><div class="stat-num">${ok}</div><div class="stat-label">${t('stat.ok')}</div></div>
    ${soft>0?`<div class="stat-card" style="border-color:rgba(249,115,22,.4)"><div class="stat-num" style="color:#f97316">${soft}</div><div class="stat-label">${t('stat.soft')}</div></div>`:''}
    ${dup>0?`<div class="stat-card" style="border-color:rgba(168,85,247,.4)"><div class="stat-num" style="color:#a855f7">${dup}</div><div class="stat-label">${t('stat.dup')}</div></div>`:''}
  `;
  document.getElementById('results-sub').textContent = t('results.sub', S.date);

  document.getElementById('t-head').innerHTML = `<tr>
    <th>${t('th.n')}</th><th>${t('th.elem')}</th><th>${t('th.tipo')}</th>
    <th>${t('th.clave')}</th><th>${t('th.prob')}</th><th>${t('th.det')}</th>
  </tr>`;

  const tbody = document.getElementById('t-body');
  if (I.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><div class="empty-icon">✅</div><div>${t('empty')}</div></div></td></tr>`;
  } else {
    const typeMap = { par:'tp.par par t-par', nar:'tp.nar nar t-nar', ref:'tp.ref ref t-ref', mul:'tp.mul mul t-mul' };
    const issMap  = { huer:'iss.huer b-huer', fant:'iss.fant b-fant', soft:'iss.soft b-soft', dup:'iss.dup b-dup' };
    tbody.innerHTML = I.map((x,i) => {
      const [tKey,tCls] = (typeMap[x.type]||'tp.par par t-par').split(' ');
      const [iKey,iCls] = (issMap[x.iss]||'iss.huer b-huer').split(' ');
      const short = (x.raw||'').length>90 ? (x.raw||'').slice(0,87)+'…' : (x.raw||'');
      return `<tr>
        <td class="num-cell">${i+1}</td>
        <td><div class="cell-text" title="${escHtml(x.raw)}">${escHtml(short)}</div></td>
        <td><span class="type-tag ${tCls}">${t(tKey)}</span></td>
        <td><span class="cell-key">${escHtml(x.fa||'')}, ${x.year||''}</span></td>
        <td><span class="badge ${iCls}">${t(iKey)}</span></td>
        <td><div class="cell-text">${t('det.'+x.iss)}</div></td>
      </tr>`;
    }).join('');
  }

  const rs = document.getElementById('results-section');
  rs.style.display = 'block';
  setTimeout(() => rs.scrollIntoView({ behavior:'smooth', block:'start' }), 50);
}

function stripHtml(s) { const d=document.createElement('div'); d.innerHTML=s; return d.textContent; }

