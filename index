<!DOCTYPE html>
<html lang="es" data-theme="oscuro">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BiblioCrossing — Verificador de coherencia de citas APA 7</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;600&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#0f1117;--surface:#1a1d2e;--surface2:#222539;--border:#2e3250;--accent:#6366f1;--accent2:#38bdf8;--accent3:#a78bfa;--verde:#34d399;--amarillo:#fbbf24;--rojo:#f87171;--texto:#e2e8f0;--texto-dim:#94a3b8;--radio:10px}
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--font-body,'IBM Plex Sans',system-ui,sans-serif);background:var(--bg);color:var(--texto);min-height:100vh}

    [data-theme="oscuro"]{--bg:oklch(0.17 0.022 270);--surface:oklch(0.21 0.02 270);--surface2:oklch(0.16 0.018 270);--border:oklch(0.30 0.02 270);--accent:oklch(0.58 0.18 275);--accent2:oklch(0.65 0.13 230);--accent3:oklch(0.62 0.15 300);--verde:oklch(0.70 0.14 150);--amarillo:oklch(0.78 0.13 85);--rojo:oklch(0.65 0.18 25);--texto:oklch(0.92 0.01 270);--texto-dim:oklch(0.72 0.02 270);--radio:16px;--radio-btn:11px;--font-display:'Space Grotesk',system-ui,sans-serif;--font-body:'IBM Plex Sans',system-ui,sans-serif;--font-mono:'IBM Plex Mono','Courier New',monospace}
    [data-theme="claro"]{--bg:oklch(0.985 0.012 285);--surface:#fff;--surface2:oklch(0.985 0.008 285);--border:oklch(0.93 0.015 285);--accent:oklch(0.64 0.15 285);--accent2:oklch(0.62 0.14 250);--accent3:oklch(0.60 0.15 300);--verde:oklch(0.70 0.13 150);--amarillo:oklch(0.78 0.13 80);--rojo:oklch(0.66 0.16 25);--texto:oklch(0.30 0.03 280);--texto-dim:oklch(0.52 0.03 280);--radio:20px;--radio-btn:13px;--font-display:'Plus Jakarta Sans',system-ui,sans-serif;--font-body:'Plus Jakarta Sans',system-ui,sans-serif;--font-mono:'IBM Plex Mono','Courier New',monospace}
    [data-theme="sobrio"]{--bg:oklch(0.975 0.01 85);--surface:#fff;--surface2:oklch(0.975 0.01 85);--border:oklch(0.84 0.01 250);--accent:oklch(0.34 0.06 250);--accent2:oklch(0.40 0.07 250);--accent3:oklch(0.46 0.05 250);--verde:oklch(0.50 0.10 150);--amarillo:oklch(0.62 0.11 70);--rojo:oklch(0.50 0.15 25);--texto:oklch(0.28 0.015 250);--texto-dim:oklch(0.46 0.02 250);--radio:6px;--radio-btn:7px;--font-display:'Source Serif 4',Georgia,serif;--font-body:'IBM Plex Sans',system-ui,sans-serif;--font-mono:'IBM Plex Mono','Courier New',monospace}

    /* HEADER */
    header{position:relative;overflow:hidden;padding:36px 40px 32px}
    .hdr-grad{position:absolute;inset:0;background:linear-gradient(108deg,oklch(0.26 0.07 285),oklch(0.27 0.06 250));z-index:0}
    [data-theme="sobrio"] header{background:var(--bg)!important;border-bottom:2px solid oklch(0.30 0.03 250);padding:20px 40px!important}
    [data-theme="sobrio"] .hdr-grad,[data-theme="sobrio"] .orb{display:none!important}
    .orb{position:absolute;border-radius:50%;filter:blur(60px);opacity:.3;animation:orbFloat 10s ease-in-out infinite;pointer-events:none;z-index:0}
    .orb-1{width:280px;height:280px;background:#6366f1;top:-80px;right:10%}
    .orb-2{width:200px;height:200px;background:#38bdf8;bottom:-60px;right:30%;animation-delay:-3s}
    .orb-3{width:150px;height:150px;background:#a78bfa;top:20px;left:40%;animation-delay:-6s}
    @keyframes orbFloat{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(20px,-15px) scale(1.05)}66%{transform:translate(-10px,10px) scale(.95)}}
    .hdr-content{position:relative;z-index:1;display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:20px}
    .logo-line{display:flex;align-items:center;gap:4px}
    .logo-icon{font-size:32px;filter:drop-shadow(0 0 12px rgba(99,102,241,.8));animation:iconPulse 3s ease-in-out infinite}
    @keyframes iconPulse{0%,100%{filter:drop-shadow(0 0 12px rgba(99,102,241,.8))}50%{filter:drop-shadow(0 0 24px rgba(167,139,250,.9))}}
    [data-theme="sobrio"] .logo-icon{animation:none;filter:none}
    .logo-text{font-family:var(--font-display,'Space Grotesk',sans-serif);font-size:28px;font-weight:800;letter-spacing:-.5px;color:#fff}
    .logo-text .accent{background:linear-gradient(90deg,var(--accent2),var(--accent3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    [data-theme="sobrio"] .logo-text{color:var(--texto)}
    [data-theme="sobrio"] .logo-text .accent{-webkit-text-fill-color:var(--accent2);background:none;color:var(--accent2)}
    .logo-sub{font-size:13px;color:rgba(255,255,255,.55);margin-top:6px}
    [data-theme="sobrio"] .logo-sub{color:var(--texto-dim)}
    .logo-placa{background:transparent;border-radius:0;padding:0}
    [data-theme="claro"] .logo-placa{background:oklch(0.20 0.03 265);border-radius:15px;padding:8px 12px}
    [data-theme="sobrio"] .logo-placa{background:oklch(0.19 0.03 255);border-radius:11px;padding:8px 12px}
    .hdr-right{display:flex;flex-direction:column;align-items:flex-end;gap:10px}
    .controls-row{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
    .ctrl-divider{width:1px;height:28px;background:rgba(255,255,255,.18)}
    [data-theme="sobrio"] .ctrl-divider{background:var(--border)}

    /* CONTROLS */
    .ctrl-group{display:flex;flex-direction:column;align-items:center;gap:5px}
    .ctrl-label{font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.35);font-family:var(--font-mono,'monospace')}
    [data-theme="sobrio"] .ctrl-label,[data-theme="claro"] .ctrl-label{color:rgba(255,255,255,.55)}
    [data-theme="sobrio"] .ctrl-label{color:var(--texto-dim)!important}
    .sw-track{display:flex;background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:3px;gap:2px}
    [data-theme="sobrio"] .sw-track{background:transparent;border-color:var(--border)}
    .sw-btn{background:transparent;border:none;color:rgba(255,255,255,.4);font-size:12px;font-weight:700;padding:5px 14px;border-radius:6px;cursor:pointer;letter-spacing:.5px;transition:all .2s;font-family:var(--font-body,inherit)}
    .sw-btn.active{background:linear-gradient(135deg,rgba(99,102,241,.7),rgba(56,189,248,.5));color:#fff;box-shadow:0 1px 6px rgba(99,102,241,.4)}
    .sw-btn:hover:not(.active){color:rgba(255,255,255,.7);background:rgba(255,255,255,.06)}
    [data-theme="sobrio"] .sw-btn{color:var(--texto-dim)!important}
    [data-theme="sobrio"] .sw-btn.active{color:var(--texto)!important;background:var(--surface)!important;border:1px solid var(--border);box-shadow:none}
    .skin-btn{padding:5px 10px;font-size:13px}
    .btn-about{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.85);font-size:12px;font-weight:600;padding:6px 14px;border-radius:8px;cursor:pointer;transition:all .15s;font-family:var(--font-body,inherit)}
    .btn-about:hover{background:rgba(255,255,255,.2);color:#fff}
    [data-theme="sobrio"] .btn-about{border-color:var(--border);color:var(--texto-dim);background:transparent}

    /* LAYOUT */
    .container{max-width:1100px;margin:0 auto;padding:28px 24px}
    .card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radio);padding:24px;margin-bottom:20px}
    [data-theme="claro"] .card{box-shadow:0 18px 44px -28px oklch(0.55 0.08 285 / .55)}
    [data-theme="sobrio"] .card{box-shadow:none}
    .card-title{font-family:var(--font-display,sans-serif);font-size:13px;font-weight:600;color:var(--accent2);margin-bottom:16px;display:flex;align-items:center;gap:8px;text-transform:uppercase;letter-spacing:.8px}
    .hint{font-size:12.5px;color:var(--texto-dim);margin-bottom:14px;line-height:1.65}

    /* TABS */
    .input-tabs{display:flex;gap:4px;margin-bottom:18px;background:var(--surface2);padding:4px;border-radius:10px;width:fit-content}
    .tab-btn{background:transparent;border:none;color:var(--texto-dim);font-size:13px;font-weight:500;padding:8px 18px;border-radius:7px;cursor:pointer;transition:all .15s;font-family:var(--font-body,inherit)}
    .tab-btn.active{background:var(--accent);color:#fff;box-shadow:0 2px 8px rgba(99,102,241,.3)}
    .tab-btn:hover:not(.active){color:var(--texto);background:rgba(255,255,255,.05)}
    [data-theme="sobrio"] .tab-btn.active{box-shadow:none}

    /* TEXT AREA */
    .text-input{width:100%;min-height:220px;max-height:480px;background:var(--surface2);border:1.5px solid var(--border);border-radius:10px;padding:14px;font-size:13px;font-family:var(--font-mono,'Courier New',monospace);line-height:1.7;color:var(--texto);resize:vertical;transition:border-color .2s,box-shadow .2s}
    .text-input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(99,102,241,.15)}
    .text-input::placeholder{color:var(--texto-dim);font-style:italic}

    /* UPLOAD */
    .upload-zone{border:2px dashed var(--border);border-radius:var(--radio);padding:40px 24px;text-align:center;cursor:pointer;transition:all .2s;background:var(--surface2)}
    .upload-zone:hover,.upload-zone.drag-over{border-color:var(--accent);background:rgba(99,102,241,.06)}
    .upload-icon{font-size:36px;margin-bottom:12px;opacity:.6}
    .upload-text{font-size:14px;font-weight:600;color:var(--texto);margin-bottom:6px}
    .upload-sub{font-size:12.5px;color:var(--texto-dim)}
    #file-input{display:none}
    .file-loaded{display:none;align-items:center;gap:12px;padding:14px 16px;background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.25);border-radius:10px;margin-top:12px}
    .file-name{font-size:13px;font-weight:600;color:var(--verde);flex:1}
    .file-size{font-size:11.5px;color:var(--texto-dim)}
    .btn-clear{background:none;border:none;cursor:pointer;color:var(--texto-dim);font-size:16px;padding:4px;border-radius:4px;transition:color .15s}
    .btn-clear:hover{color:var(--rojo)}

    /* NOTICE */
    .notice{margin-top:14px;padding:12px 16px;border-radius:9px;font-size:12.5px;line-height:1.65;display:none;gap:10px;align-items:flex-start}
    .notice.visible{display:flex}
    .notice-ok{background:rgba(52,211,153,.07);border:1px solid rgba(52,211,153,.25);color:var(--texto)}
    .notice-warn{background:rgba(251,191,36,.07);border:1px solid rgba(251,191,36,.25);color:var(--texto)}
    .notice-icon{font-size:16px;flex-shrink:0;margin-top:1px}

    /* BUTTONS */
    .btn-row{display:flex;gap:10px;margin-top:18px;flex-wrap:wrap;align-items:center}
    button{cursor:pointer;border:none;border-radius:var(--radio-btn,8px);font-size:13.5px;font-weight:600;padding:10px 22px;transition:all .15s;display:inline-flex;align-items:center;gap:6px;font-family:var(--font-body,inherit)}
    .btn-primary{background:linear-gradient(135deg,var(--accent),oklch(0.52 0.19 270));color:#fff;box-shadow:0 4px 15px rgba(99,102,241,.35)}
    .btn-primary:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 6px 20px rgba(99,102,241,.5)}
    .btn-primary:disabled{background:var(--surface2);color:var(--texto-dim);box-shadow:none;cursor:not-allowed;border:1px solid var(--border)}
    .btn-ghost{background:transparent;border:1px solid var(--border);color:var(--texto-dim)}
    .btn-ghost:hover{border-color:var(--accent3);color:var(--texto)}
    .btn-word{background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;box-shadow:0 4px 12px rgba(37,99,235,.3)}
    .btn-word:hover{transform:translateY(-1px);box-shadow:0 6px 16px rgba(37,99,235,.45)}
    .btn-excel{background:linear-gradient(135deg,#059669,#047857);color:#fff;box-shadow:0 4px 12px rgba(5,150,105,.3)}
    .btn-excel:hover{transform:translateY(-1px);box-shadow:0 6px 16px rgba(5,150,105,.45)}
    [data-theme="sobrio"] .btn-primary,[data-theme="sobrio"] .btn-word,[data-theme="sobrio"] .btn-excel{box-shadow:none}
    [data-theme="sobrio"] .btn-primary:hover:not(:disabled),[data-theme="sobrio"] .btn-word:hover,[data-theme="sobrio"] .btn-excel:hover{transform:none}

    /* RESULTS */
    #results-section{display:none}
    .results-heading{font-family:var(--font-display,sans-serif);font-size:18px;font-weight:700;color:var(--texto);margin-bottom:4px}
    .results-sub{font-size:13px;color:var(--texto-dim);margin-bottom:20px}
    .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:24px}
    .stat-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;text-align:center}
    .stat-num{font-family:var(--font-display,sans-serif);font-size:28px;font-weight:800;margin-bottom:4px}
    .stat-label{font-size:11.5px;color:var(--texto-dim);font-weight:500;line-height:1.4}
    .s-citas .stat-num{color:var(--accent2)}.s-refs .stat-num{color:var(--accent3)}.s-huer .stat-num{color:var(--rojo)}.s-fant .stat-num{color:var(--amarillo)}.s-mult .stat-num{color:var(--texto-dim)}.s-ok .stat-num{color:var(--verde)}

    /* TABLE */
    .table-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:var(--radio)}
    table{width:100%;border-collapse:collapse;font-size:13px}
    thead th{background:var(--surface2);color:var(--texto-dim);padding:11px 14px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;border-bottom:1px solid var(--border);white-space:nowrap}
    tbody tr{border-bottom:1px solid var(--border);transition:background .1s}
    tbody tr:last-child{border-bottom:none}
    tbody tr:hover{background:rgba(99,102,241,.04)}
    td{padding:12px 14px;vertical-align:top;background:var(--surface)}
    .cell-text{font-size:12.5px;color:var(--texto-dim);max-width:320px;line-height:1.55}
    .cell-key{font-family:var(--font-mono,monospace);font-size:12px;color:var(--accent3)}
    .num-cell{color:var(--texto-dim);font-weight:600;white-space:nowrap;min-width:32px}

    /* BADGES */
    .badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:12px;font-size:11.5px;font-weight:600;white-space:nowrap;border:1px solid}
    .b-huer{color:var(--rojo);border-color:rgba(248,113,113,.3);background:rgba(248,113,113,.08)}
    .b-fant{color:var(--amarillo);border-color:rgba(251,191,36,.3);background:rgba(251,191,36,.08)}
    .b-mult{color:var(--texto-dim);border-color:var(--border);background:var(--surface2)}
    .b-soft{color:#f97316;border-color:rgba(249,115,22,.3);background:rgba(249,115,22,.08)}
    .b-dup{color:#a855f7;border-color:rgba(168,85,247,.3);background:rgba(168,85,247,.08)}
    .type-tag{display:inline-flex;align-items:center;padding:2px 8px;border-radius:6px;font-size:10.5px;font-weight:600;letter-spacing:.3px}
    .t-par{background:rgba(56,189,248,.1);color:var(--accent2)}
    .t-nar{background:rgba(167,139,250,.1);color:var(--accent3)}
    .t-ref{background:rgba(52,211,153,.1);color:var(--verde)}
    .t-mul{background:rgba(148,163,184,.1);color:var(--texto-dim)}

    /* DISCLAIMER */
    .disclaimer{margin-top:16px;padding:14px 18px;border-radius:var(--radio);background:rgba(99,102,241,.06);border:1px solid rgba(99,102,241,.2);font-size:12.5px;color:var(--texto-dim);line-height:1.65}
    .disclaimer strong{color:var(--accent3)}

    /* FOOTER */
    .footer-bar{margin-top:32px;padding:18px 22px;border:1px solid var(--border);border-radius:var(--radio);background:var(--surface);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px}
    .footer-info{font-size:12px;color:var(--texto-dim);line-height:1.65}
    .footer-info strong{color:var(--texto)}
    .cc-link{display:inline-flex;align-items:center;gap:6px;font-size:11px;color:var(--texto-dim);text-decoration:none}
    .cc-link img{height:20px;opacity:.7;transition:opacity .15s}
    .cc-link:hover img{opacity:1}

    /* ABOUT MODAL */
    .overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:1000;align-items:center;justify-content:center;padding:24px;backdrop-filter:blur(4px)}
    .overlay.open{display:flex}
    .modal{background:var(--surface);border:1px solid var(--border);border-radius:16px;max-width:720px;width:100%;max-height:85vh;overflow-y:auto;box-shadow:0 24px 64px rgba(0,0,0,.35);animation:modalIn .2s ease}
    @keyframes modalIn{from{opacity:0;transform:translateY(12px) scale(.98)}to{opacity:1;transform:none}}
    .modal-hdr{display:flex;align-items:center;gap:12px;padding:24px 28px 0}
    .modal-icon{font-size:26px}
    .modal-title{font-family:var(--font-display,sans-serif);font-size:20px;font-weight:700;color:var(--texto);flex:1;margin:0}
    .modal-close{background:none;border:none;cursor:pointer;color:var(--texto-dim);font-size:20px;line-height:1;padding:4px 8px;border-radius:6px;transition:background .15s;font-family:inherit}
    .modal-close:hover{background:var(--border);color:var(--texto)}
    .modal-body{padding:20px 28px 28px;font-size:14px;color:var(--texto-dim);line-height:1.85}
    .modal-body p{margin-bottom:16px}
    .modal-body p:last-child{margin-bottom:0}
    .modal-body strong{color:var(--texto)}
    .modal-divider{border:none;border-top:1px solid var(--border);margin:20px 0}
    .modal-meta{font-size:12px;color:var(--texto-dim);display:flex;flex-direction:column;gap:6px}

    /* EMPTY */
    .empty-state{text-align:center;padding:40px 24px;color:var(--texto-dim)}
    .empty-icon{font-size:40px;margin-bottom:12px;opacity:.5}

    /* RESPONSIVE */
    @media(max-width:600px){
      header{padding:24px 20px 20px}
      .logo-text{font-size:22px}
      .container{padding:18px 14px}
      .controls-row{gap:8px}
    }
  </style>
</head>
<body>

<header>
  <div class="hdr-grad"></div>
  <div class="orb orb-1"></div><div class="orb orb-2"></div><div class="orb orb-3"></div>
  <div class="hdr-content">
    <div class="logo-area">
      <div class="logo-line">
        <div class="logo-placa">
          <img id="logo-img" src="" alt="BiblioCrossing" style="height:132px;width:auto;display:block;">
        </div>
        <div class="logo-sub" data-i18n="header.sub" style="font-size:12px;color:rgba(255,255,255,0.55);margin-left:-16px">Verificador de coherencia entre citas y referencias · APA 7</div>
      </div>
    </div>
    <div class="hdr-right">
      <div class="controls-row">
        <div class="ctrl-group">
          <span class="ctrl-label" data-i18n="ctrl.lang">Idioma</span>
          <div class="sw-track">
            <button class="sw-btn active" data-lang="es">ES</button>
            <button class="sw-btn" data-lang="en">EN</button>
          </div>
        </div>
        <div class="ctrl-divider"></div>
        <div class="ctrl-group">
          <span class="ctrl-label" data-i18n="ctrl.theme">Tema</span>
          <div class="sw-track">
            <button class="sw-btn skin-btn active" data-skin="oscuro">🌑</button>
            <button class="sw-btn skin-btn" data-skin="claro">☀️</button>
            <button class="sw-btn skin-btn" data-skin="sobrio">📄</button>
          </div>
        </div>
        <div class="ctrl-divider"></div>
        <button class="btn-about" id="btn-about" data-i18n="btn.about">Acerca de</button>
      </div>
    </div>
  </div>
</header>

<main>
  <div class="container">

    <!-- INPUT -->
    <div class="card">
      <div class="card-title"><span>📄</span><span data-i18n="card.input">Entrada del documento</span></div>
      <div class="input-tabs">
        <button class="tab-btn active" data-tab="paste" data-i18n="tab.paste">Pegar texto</button>
        <button class="tab-btn" data-tab="upload" data-i18n="tab.upload">Subir .docx</button>
      </div>

      <!-- PASTE -->
      <div id="panel-paste">
        <div class="hint" data-i18n="hint.paste">Pega el texto completo del manuscrito incluyendo la sección de Referencias al final. Se detecta automáticamente el encabezado en español ("Referencias", "Bibliografía", "Fuentes consultadas"…) o en inglés ("References", "Bibliography", "Works Cited"…), con o sin numeración y tolerando errores tipográficos.</div>
