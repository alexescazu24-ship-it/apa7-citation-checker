// ═══════════════════════════════════════
// EXPORT EXCEL
// ═══════════════════════════════════════
function exportExcel() {
  if (typeof XLSX === 'undefined') { alert('SheetJS no disponible'); return; }
  const { citations: C, references: R, issues: I, date: D } = S;
  const headers = [t('th.n'), t('th.elem'), t('th.tipo'), t('th.clave'), t('th.prob'), t('th.det')];
  const dataRows = I.map((x,i) => [
    i+1, x.raw||'',
    T[S.lang]['tp.'+x.type]||x.type,
    `${x.fa||''}, ${x.year||''}`,
    T[S.lang]['iss.'+x.iss]||x.iss,
    T[S.lang]['det.'+x.iss]||''
  ]);
  const summaryRows = [
    ['BiblioCrossing — ' + t('exp.subtitle')],
    [t('exp.date'), D],
    [],
    [t('stat.citas'), C.length],
    [t('stat.refs'), R.length],
    [t('stat.huer'), I.filter(x=>x.iss==='huer').length],
    [t('stat.fant'), I.filter(x=>x.iss==='fant').length],
    [t('stat.mult'), C.filter(c=>c.isMulti).length],
    [t('stat.ok'), C.filter(c=>R.some(r=>r.key===c.key)).length],
    [t('stat.soft'), I.filter(x=>x.iss==='soft').length],
    [t('stat.dup'),  I.filter(x=>x.iss==='dup').length],
    [],
    [t('exp.by')]
  ];

  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet([headers,...dataRows]);
  ws['!cols'] = [{wch:5},{wch:48},{wch:14},{wch:18},{wch:24},{wch:52}];
  XLSX.utils.book_append_sheet(wb, ws, S.lang==='es'?'Inconsistencias':'Issues');
  const ws2 = XLSX.utils.aoa_to_sheet(summaryRows);
  ws2['!cols'] = [{wch:32},{wch:20}];
  XLSX.utils.book_append_sheet(wb, ws2, S.lang==='es'?'Resumen':'Summary');
  XLSX.writeFile(wb, `BiblioCrossing_${new Date().toISOString().slice(0,10)}.xlsx`);
}

// ═══════════════════════════════════════
// FILE UPLOAD
// ═══════════════════════════════════════
function handleFile(file) {
  if (!file) return;
  if (!file.name.toLowerCase().endsWith('.docx')) { alert('Solo se aceptan archivos .docx'); return; }
  showNotice('upload', 'proc');

  document.getElementById('file-name').textContent = file.name;
  document.getElementById('file-size').textContent = fmtSize(file.size);
  document.getElementById('file-loaded').style.display = 'flex';

  const reader = new FileReader();
  reader.onload = e => {
    if (typeof mammoth === 'undefined') {
      showNotice('upload', 'warn'); return;
    }
    mammoth.extractRawText({ arrayBuffer: e.target.result })
      .then(res => {
        S.rawText = res.value;
        const { refs, found } = splitDoc(res.value);
        if (found) {
          const n = parseRefList(refs).refs.length;
          showNotice('upload', 'ok', n);
          document.getElementById('btn-analyze').disabled = false;
        } else {
          showNotice('upload', 'warn');
        }
      })
      .catch(err => {
        const el = document.getElementById('notice-upload');
        el.innerHTML = `<span class="notice-icon">❌</span><span>Error: ${escHtml(err.message)}</span>`;
        el.className = 'notice notice-warn visible';
      });
  };
  reader.readAsArrayBuffer(file);
}

function showNotice(panel, type, n) {
  const el = document.getElementById('notice-' + panel);
  if (type === 'ok') {
    el.innerHTML = `<span class="notice-icon">✅</span><span>${t('notice.ok',n)}</span>`;
    el.className = 'notice notice-ok visible';
  } else if (type === 'warn') {
    el.innerHTML = `<span class="notice-icon">⚠️</span><span>${t('notice.warn')}</span>`;
    el.className = 'notice notice-warn visible';
  } else {
    el.innerHTML = `<span class="notice-icon">⏳</span><span>${t('notice.proc')}</span>`;
    el.className = 'notice notice-ok visible';
  }
}

function clearFile() {
  S.rawText = '';
  document.getElementById('file-loaded').style.display = 'none';
  document.getElementById('notice-upload').className = 'notice';
  document.getElementById('file-input').value = '';
  document.getElementById('btn-analyze').disabled = true;
}

// ═══════════════════════════════════════
// PASTE DETECTION
// ═══════════════════════════════════════
function checkPaste() {
  const val = document.getElementById('text-body').value;
  if (val.trim().length < 50) {
    document.getElementById('notice-paste').className = 'notice';
    document.getElementById('btn-analyze').disabled = true;
    return;
  }
  const { refs, found } = splitDoc(val);
  if (found) {
    const n = parseRefList(refs).length;
    showNotice('paste', 'ok', n);
    document.getElementById('btn-analyze').disabled = false;
  } else {
    showNotice('paste', 'warn');
    document.getElementById('btn-analyze').disabled = true;
  }
}

// ═══════════════════════════════════════
// CLEAR ALL
// ═══════════════════════════════════════
function clearAll() {
  document.getElementById('text-body').value = '';
  S.rawText = '';
  clearFile();
  document.getElementById('notice-paste').className = 'notice';
  document.getElementById('results-section').style.display = 'none';
  document.getElementById('btn-analyze').disabled = true;
  S.citations = []; S.references = []; S.issues = [];
}

// ═══════════════════════════════════════
// LANG / THEME
// ═══════════════════════════════════════
function applyLang(lang) {
  S.lang = lang;
  document.querySelectorAll('[data-lang]').forEach(b => b.classList.toggle('active', b.dataset.lang === lang));
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const v = T[lang][el.dataset.i18n];
    if (v && typeof v === 'string') el.textContent = v;
  });
  document.querySelectorAll('[data-i18n-ph]').forEach(el => {
    const v = T[lang][el.dataset.i18nPh];
    if (v) el.placeholder = v;
  });
  // Re-render if results visible
  if (document.getElementById('results-section').style.display !== 'none') renderResults();
  checkPaste();
}

function applyTheme(skin) {
  document.documentElement.setAttribute('data-theme', skin);
  document.querySelectorAll('[data-skin]').forEach(b => b.classList.toggle('active', b.dataset.skin === skin));
}

// ═══════════════════════════════════════
// ABOUT
// ═══════════════════════════════════════
function openAbout() {
  document.getElementById('about-body').innerHTML = T[S.lang]['about.body'];
  document.getElementById('about-overlay').classList.add('open');
}
function closeAbout() { document.getElementById('about-overlay').classList.remove('open'); }

// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  // Lang
  document.querySelectorAll('[data-lang]').forEach(b => b.addEventListener('click', () => applyLang(b.dataset.lang)));
  // Skin
  document.querySelectorAll('[data-skin]').forEach(b => b.addEventListener('click', () => applyTheme(b.dataset.skin)));
  // About
  document.getElementById('btn-about').addEventListener('click', openAbout);
  document.getElementById('btn-close-about').addEventListener('click', closeAbout);
  document.getElementById('about-overlay').addEventListener('click', e => { if (e.target===document.getElementById('about-overlay')) closeAbout(); });
  document.addEventListener('keydown', e => { if (e.key==='Escape') closeAbout(); });
  // Tabs
  document.querySelectorAll('.tab-btn').forEach(b => b.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    const tab = b.dataset.tab;
    document.getElementById('panel-paste').style.display = tab==='paste' ? 'block' : 'none';
    document.getElementById('panel-upload').style.display = tab==='upload' ? 'block' : 'none';
    document.getElementById('btn-analyze').disabled = tab==='paste' ? !document.getElementById('text-body').value.trim() : !S.rawText;
    if (tab==='paste') checkPaste();
  }));
  // Paste textarea
  document.getElementById('text-body').addEventListener('input', debounce(checkPaste, 600));
  document.getElementById('text-body').addEventListener('paste', () => setTimeout(checkPaste, 150));
  // File
  document.getElementById('file-input').addEventListener('change', e => { if (e.target.files[0]) handleFile(e.target.files[0]); });
  document.getElementById('btn-clear-file').addEventListener('click', clearFile);
  // Upload zone click
  document.getElementById('upload-zone').addEventListener('click', () => document.getElementById('file-input').click());
  // Drag & drop
  const uz = document.getElementById('upload-zone');
  uz.addEventListener('dragover', e => { e.preventDefault(); uz.classList.add('drag-over'); });
  uz.addEventListener('dragleave', () => uz.classList.remove('drag-over'));
  uz.addEventListener('drop', e => { e.preventDefault(); uz.classList.remove('drag-over'); if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); });
  // Buttons
  document.getElementById('btn-analyze').addEventListener('click', runAnalysis);
  document.getElementById('btn-clear-all').addEventListener('click', clearAll);
  document.getElementById('btn-word').addEventListener('click', exportWord);
  document.getElementById('btn-excel').addEventListener('click', exportExcel);

  applyLang('es');
});
</script>
